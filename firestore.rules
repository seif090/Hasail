rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function getUserData(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }

    function hasRole(role) {
      return isSignedIn() && getUserData(request.auth.uid).role == role;
    }

    function isAdmin() {
      return hasRole('admin');
    }

    // --- Collections ---

    // Users
    match /users/{userId} {
      allow read: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow create: if isSignedIn() && isOwner(userId) && request.resource.data.role == 'investor'; // Default to investor on self-signup
      allow update: if isSignedIn() && isOwner(userId) && (
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'uid', 'email'])
      );
    }

    // Opportunities
    match /opportunities/{opportunityId} {
      allow read: if true; // Public listings
      allow write: if isAdmin();
    }

    // Farms
    match /farms/{farmId} {
      allow read: if isSignedIn(); // Basic farm info might be public, or restricted to members
      allow write: if isAdmin();
    }

    // Activities
    match /activities/{activityId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (hasRole('operator') || isAdmin()) && request.resource.data.operatorId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // Investments
    match /investments/{investmentId} {
      allow read: if isSignedIn() && (request.auth.uid == resource.data.investorId || isAdmin());
      allow create: if isSignedIn() && request.resource.data.investorId == request.auth.uid;
      allow update, delete: if isAdmin();
    }
  }
}
